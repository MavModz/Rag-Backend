# --- Ollama (running locally) ---
OLLAMA_BASE_URL=http://localhost:11434
# Embedding model (vectors only). mxbai-embed-large -> 1024-dim vectors.
# Changing this changes the vector dimension; after switching, run
# `python -m scripts.reset_vectors --yes` (server stopped) and re-ingest.
# Pull first: `ollama pull mxbai-embed-large`.
OLLAMA_EMBED_MODEL=mxbai-embed-large:latest
# Chat/generation model — MUST be a generative model, not an embedding model.
# Pull one first: `ollama pull qwen2.5:7b-instruct` (or qwen3:8b)
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_REQUEST_TIMEOUT=120
OLLAMA_TEMPERATURE=0.2

# --- Data sources (per-tenant; NO global database) ---
# The platform is database-independent: each tenant connects their own DB via the
# Data Sources screen; connection strings are stored (encrypted) in the Postgres
# AI DB, not here. Set this key to encrypt them at rest:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_SOURCE_ENCRYPTION_KEY=

# --- Qdrant (embedded/local; on-disk path, no Docker) ---
QDRANT_PATH=./data/qdrant
QDRANT_COLLECTION=kb_documents

# --- Retrieval / chunking ---
# Smaller TOP_K / HISTORY_LIMIT = shorter prompt = much faster first token on CPU.
TOP_K=3
CHUNK_SIZE=800
CHUNK_OVERLAP=120
HISTORY_LIMIT=4

# --- Uploads ---
UPLOAD_DIR=./data/uploads

# =====================================================================
# Platform foundation (M1)
# =====================================================================

# --- PostgreSQL (primary platform DB) ---
# Docker compose uses: postgresql+asyncpg://postgres:postgres@postgres:5432/ai_platform
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_platform
POSTGRES_POOL_SIZE=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
JWT_SECRET=dev-insecure-change-me
# LMS/CRM end-user JWT validation (separate from platform JWT_SECRET above).
LMS_JWT_SECRET=
CRM_JWT_SECRET=
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
# Dev: requests with no credentials get a full-access anonymous context.
# MUST be false in production.
AUTH_ALLOW_ANONYMOUS=true
# Must be a real/deliverable-domain email (EmailStr rejects reserved TLDs like .local).
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin12345

# --- Object storage (local | s3/MinIO) ---
OBJECT_STORE_BACKEND=local
STORAGE_ROOT=./data/storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ai-platform
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Model Gateway ---
GATEWAY_DEFAULT_RETRIES=2
GATEWAY_TIMEOUT=120

# --- Rate limiting (memory:// in dev; redis://redis:6379/1 in prod) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_INGEST=10/minute
RATE_LIMIT_STORAGE_URI=memory://

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=text
METRICS_ENABLED=true

# --- Worker / events (empty broker -> in-process bus, no Celery worker) ---
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- Switching the chat model/provider (Model Gateway) ---
# Default is local Ollama. To use an OpenAI-compatible API instead (OpenAI,
# NVIDIA NIM, Groq, Together, ...), set CHAT_PROVIDER=openai and the three vars.
# Example — NVIDIA's free API (https://build.nvidia.com):
#   CHAT_PROVIDER=openai
#   OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
#   OPENAI_API_KEY=nvapi-xxxxxxxx
#   OPENAI_CHAT_MODEL=meta/llama-3.1-8b-instruct
CHAT_PROVIDER=ollama
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=

# --- Memory (learn from past chats) ---
MEMORY_ENABLED=true
QDRANT_MEMORY_COLLECTION=memory
MEMORY_TOP_K=3
MEMORY_REFLECT_MIN_ANSWER_CHARS=40
MEMORY_MIN_SCORE=0.55

# --- Onboarding ---
# Public self-serve signup for standalone purchasers. Set false for a
# parent-provisioned-only deployment.
ALLOW_PUBLIC_REGISTRATION=true
DEFAULT_SIGNUP_PLAN=free
# Shared secret for purchase-time provisioning and platform doc ingest
# (POST /provisioning/tenants, POST /platform/ingest), sent as X-Provisioning-Key.
# Generate: openssl rand -hex 32 — see docs/INTEGRATION_WHATSAPP.md
PROVISIONING_API_KEY=

# NRICH Knowledge Base API (platform open-blogs sync)
NRICH_KB_API_BASE_URL=https://knowledgebasebackend.nrichlearning.com
NRICH_KB_API_TIMEOUT=60.0
